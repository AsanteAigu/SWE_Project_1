# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Neon Postgres connection string, e.g.
# postgres://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Random 32+ character secret used to encrypt the session cookie.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
